# Supabase (client-safe). Copy to .env.local and fill in real values.
# Get these from: Supabase Dashboard → Project Settings → API
#
# The anon key is safe to expose in the browser; RLS protects your data.
# Do NOT put service_role keys or database passwords in this file.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (optional): required for self-serve account deletion in Settings
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL for password reset emails (defaults to http://localhost:3000 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudinary (cat photo + sticker uploads)
# Cloud name is public; API key + secret are server-only (never use NEXT_PUBLIC_).
# Create a free account at https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Hugging Face (optional): server-only read token for CLIP embeddings via /api/ml/hf proxy.
# Create at https://huggingface.co/settings/tokens — cat detection uses TensorFlow.js instead.
# HF_TOKEN=hf_...

# --- Vercel deployment ---
# 1. Import this repo in Vercel (framework: Next.js; build uses webpack for Serwist PWA).
# 2. Add all variables above in Project Settings → Environment Variables.
# 3. In Supabase → Authentication → URL Configuration, set:
#    Site URL: https://<your-vercel-domain>
#    Redirect URLs: https://<your-vercel-domain>/auth/callback
# 4. Node 20+ is required (set in package.json engines).
